.wrapper
	position: relative
	width: 920px
	height: 600px
	margin: 20px auto
	padding: 50px 40px
	background-color: rgba(255, 248, 240, 1.0)

p
	padding: 0

.helpButton
	margin-left: 200px
.tagContainer
	margin-bottom: 20px
	display: flex
	justify-content:space-around
.audioTagLabel
	display: inline-block
	height: 180px
	line-height: 180px
.audioTag
	display: inline-block
	height: 110px

.videoTagLabel
	display: inline-block
	height: 180px
	line-height: 180px
.videoTag
	display: inline-block
	height: 180px

.webaudioContainer
	display: flex
	justify-content: center
.mp3ChannelContainer
	border-right: 4px solid #b71c1c
.mp3ChannelContainer
	width: 50%
	padding: 20px 0
	text-align: center
	button
		font-size: 20px
		font-weight: bold
		line-height: 20px
	.audioTagButton
		margin: 10px 70px 0 10px
	.audioBufferButton
		margin: 10px 40px 0 10px
.mp4ChannelContainer
	width: 50%
	padding: 20px 0
	text-align: center
	button
		margin-top: 34px
		font-size: 20px
		font-weight: bold
		line-height: 20px
.helpContainer
	position: absolute
	top: 20px
	right: 20px
	width: 95%
	z-index: 100
	height: 560px

	overflow: auto
	text-align: left
	padding: 10px 10px 40px
	color: rgba(255, 250, 240, 0.95)
	background-color: rgba(0, 0, 0, 0.85)
	h1
		display: inline-block
		padding-top: 10px
	img
		width: 600px
		height: auto
		margin: 10px 0 10px 80px
	button
		position: sticky
		top: 10px
		left: 760px
	a
		display: block
		color: var(--primary-color)
		text-decoration: none
		margin-left: 40px
		margin-bottom: 40px
	a:hover
		color: var(--accent-color)
		opacity: 0.6
	a:active
		color: var(--accent-color)
		opacity: 1.0
	.helpCode
		margin-left: 15px
