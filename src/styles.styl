@import "assets/brick-light.css"

body
	width: 100%
	height: 100vh
	margin: 0
	padding: 0
	background: linear-gradient(to bottom right, #cc3300 0%, #442200 100%)
	// added to stop expanding margin issue
	display: inline-block

div
	margin: 0
	padding: 0
	box-sizing: border-box

.centered
	text-align: center

// scrollbars
//
:root, div
	scrollbar-width: auto
	scrollbar-color: var(--accent-color) rgba(0, 0, 0, 0.4)
::-webkit-scrollbar
	width: 16px
	height: 16px
::-webkit-scrollbar-track
	background-color: rgba(0, 0, 0, 0.4)
::-webkit-scrollbar-thumb
	background-color: var(--accent-color)
	border-radius: 4px
